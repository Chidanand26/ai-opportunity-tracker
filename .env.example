# ─────────────────────────────────────────────────────────────────────────────
# AI Opportunity Tracker — environment configuration
#
# Setup:
#   Windows PowerShell : Copy-Item .env.example .env
#   Windows CMD        : copy .env.example .env
#   macOS / Linux      : cp .env.example .env
#
# Then fill in your values. Lines starting with # are comments and are ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="AI Opportunity Tracker"
APP_VERSION="0.1.0"
DEBUG=true
ENVIRONMENT=development

# Generate a secret key (run this in any terminal with Python):
#   python -c "import secrets; print(secrets.token_hex(32))"
# Windows users: use "python" not "python3" unless you have aliased it.
SECRET_KEY=change-me-in-production-use-a-long-random-string

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=tracker
POSTGRES_PASSWORD=tracker
POSTGRES_DB=tracker_db

# The host "db" is the Docker service name — it resolves inside the Docker
# network on all platforms (Windows, macOS, Linux). Do not change it to
# "localhost" unless you are running PostgreSQL outside Docker.
DATABASE_URL=postgresql+asyncpg://tracker:tracker@db:5432/tracker_db

# ── Redis ─────────────────────────────────────────────────────────────────────
# "redis" is the Docker service name — same note as DATABASE_URL above.
REDIS_URL=redis://redis:6379/0

# ── Celery (defaults to REDIS_URL if left blank) ──────────────────────────────
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ── LLM Provider — choose "anthropic" or "openai" ────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=claude-sonnet-4-6

# ── Email (optional — leave blank to disable notifications) ───────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_FROM_EMAIL=your-email@gmail.com

# ── Single-user MVP ───────────────────────────────────────────────────────────
# Every DB table has a user_id column from day one.
# When converting to multi-user: add auth provider settings here.
DEFAULT_USER_ID=1
