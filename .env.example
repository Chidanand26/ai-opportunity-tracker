# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_NAME="AI Opportunity Tracker"
APP_VERSION="0.1.0"
DEBUG=true
ENVIRONMENT=development

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string

# ─────────────────────────────────────────────
# CORS (comma-separated list of allowed origins)
# ─────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
POSTGRES_USER=tracker
POSTGRES_PASSWORD=tracker
POSTGRES_DB=tracker_db
# Inside Docker: use service name "db". Outside Docker: use "localhost"
DATABASE_URL=postgresql+asyncpg://tracker:tracker@db:5432/tracker_db

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
# Inside Docker: use service name "redis". Outside Docker: use "localhost"
REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────
# Celery (defaults to REDIS_URL if left blank)
# ─────────────────────────────────────────────
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ─────────────────────────────────────────────
# LLM Provider — choose "anthropic" or "openai"
# ─────────────────────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=claude-sonnet-4-6

# ─────────────────────────────────────────────
# Email (optional — leave blank to disable)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_FROM_EMAIL=your-email@gmail.com

# ─────────────────────────────────────────────
# Single-user MVP
# When converting to multi-user: add auth provider settings here
# ─────────────────────────────────────────────
DEFAULT_USER_ID=1
